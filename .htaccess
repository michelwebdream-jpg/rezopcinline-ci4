# Application dans le sous-dossier /rezopcinline/
# DocumentRoot pointe sur le parent (ex: www/), l'app est dans www/rezopcinline/
RewriteEngine On

# IMPORTANT: Forcer /rezopcinline/dev/* à être servi depuis rezopcinline/public/dev/*
RewriteRule ^dev/(.*)$ public/dev/$1 [L]

# Servir les fichiers statiques (css, js, images) depuis public/
# URL: /rezopcinline/css/style.css -> fichier: rezopcinline/public/css/style.css
RewriteCond %{REQUEST_URI} ^/rezopcinline/(.+)$
RewriteCond %{DOCUMENT_ROOT}/rezopcinline/public/%1 -f
RewriteRule ^(.*)$ public/$1 [L]

# Servir les répertoires statiques
RewriteCond %{REQUEST_URI} ^/rezopcinline/(.+)$
RewriteCond %{DOCUMENT_ROOT}/rezopcinline/public/%1 -d
RewriteRule ^(.*)$ public/$1 [L]

# Passer à index.php (y compris pour /rezopcinline/ et /rezopcinline)
# Note: on doit aussi matcher la racine car REQUEST_FILENAME -d serait vrai pour le dossier
RewriteRule ^$ index.php [L]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php [L]

# Empêcher l'accès direct aux fichiers sensibles
<FilesMatch "^(\.env|\.git|composer\.(json|lock)|\.htaccess)">
    Require all denied
</FilesMatch>

# Empêcher le listing des répertoires
Options -Indexes
